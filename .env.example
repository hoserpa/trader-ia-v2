# Trading
TRADING_MODE=demo
TRADING_PAIRS=BTC/EUR,ETH/EUR,SOL/EUR
EXCHANGE=binance
BASE_CURRENCY=EUR
DEMO_INITIAL_BALANCE=1000.0
ANALYSIS_INTERVAL_SECONDS=3600
MODEL_TIMEFRAME=1h
MODEL_CANDLES_REQUIRED=200
RESET_PORTFOLIO=false

# Risk Management
MAX_RISK_PER_TRADE_PCT=0.02
MAX_OPEN_POSITIONS=3
MAX_PORTFOLIO_IN_CRYPTO_PCT=0.60
BUY_THRESHOLD=0.40
SELL_THRESHOLD=0.40
STOP_LOSS_ATR_MULTIPLIER=1.5
TAKE_PROFIT_ATR_MULTIPLIER=3.0
MAX_DAILY_TRADES=20
HIGH_VOLATILITY_ATR_THRESHOLD=0.05
MIN_CONFIDENCE_THRESHOLD=0.0

# Exchange API (Binance)
EXCHANGE=binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Database
SQLITE_DB_PATH=/app/data/crypto_trader.db
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Model
MODEL_PATH=/app/model/trained_model.pkl
SCALER_PATH=/app/model/scaler.pkl

# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_USERNAME=admin
API_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5
