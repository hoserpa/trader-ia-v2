# Trading
TRADING_MODE=demo
TRADING_PAIRS=BTC/EUR,ETH/EUR,SOL/EUR
EXCHANGE=kraken
BASE_CURRENCY=EUR
DEMO_INITIAL_BALANCE=100.0

# Análisis - intervalo más frecuente para más oportunidades
ANALYSIS_INTERVAL_SECONDS=600
MODEL_TIMEFRAME=15m
MODEL_CANDLES_REQUIRED=200
RESET_PORTFOLIO=false

# Risk Management - objetivo 2-4%/mes, sizing conservador
MAX_RISK_PER_TRADE_PCT=0.01
MAX_OPEN_POSITIONS=1
MAX_PORTFOLIO_IN_CRYPTO_PCT=0.25

# Thresholds
BUY_THRESHOLD=0.10
SELL_THRESHOLD=0.10

STOP_LOSS_ATR_MULTIPLIER=2.0
TAKE_PROFIT_ATR_MULTIPLIER=3.0
MAX_DAILY_TRADES=6
HIGH_VOLATILITY_ATR_THRESHOLD=0.025
MIN_CONFIDENCE_THRESHOLD=0.15
CLOSE_CONFIDENCE_THRESHOLD=0.45

# Gestión de posiciones
MAX_POSITION_HOURS=4
TRAILING_STOP_ACTIVATION_PCT=0.008
TRAILING_STOP_DISTANCE_ATR=1.0
PARTIAL_EXIT_PCT=0.50
PARTIAL_EXIT_R_MULTIPLIER=1.5
COOLDOWN_MINUTES=60

# Filtros técnicos (Fase 3)
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# Grid Trading (Futures)
GRID_ENABLED=false
GRID_LEVERAGE=2
GRID_LEVELS=20
GRID_CAPITAL_PCT=0.7
GRID_RANGE_PCT=0.10
GRID_REBALANCE_THRESHOLD=0.15
GRID_STOP_LOSS_PCT=0.10
GRID_POLL_INTERVAL=30

# Exchange API (Kraken)
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# Database
SQLITE_DB_PATH=/app/data/crypto_trader.db
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Model
MODEL_PATH=/app/model/trained_model.pkl
SCALER_PATH=/app/model/scaler.pkl

# Telegram Notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API
API_HOST=0.0.0.0
API_PORT=8000
API_USERNAME=admin
API_PASSWORD=changeme

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/bot.log
LOG_MAX_SIZE_MB=50
LOG_BACKUP_COUNT=5